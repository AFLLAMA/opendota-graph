# OpenDota API Key (Optional for free tier, but recommended if you have one)
OPENDOTA_API_KEY=""

# Your Dota 2 Account ID (Steam 32-bit ID)
MY_ACCOUNT_ID="YOUR_ACCOUNT_ID_HERE"

# Pro player's Account ID
ACE_ACCOUNT_ID="ID"

# --- Grafana Cloud Configuration ---
# Loki (Logs)
GRAFANA_LOKI_URL="https://logs-prod-xxx.grafana.net/loki/api/v1/push"
GRAFANA_LOKI_USER="YOUR_LOKI_USER_ID"
GRAFANA_LOKI_API_KEY="YOUR_GRAFANA_CLOUD_API_KEY"

# Prometheus (Metrics)
# For a script like this, we usually push to a Pushgateway or use Remote Write
GRAFANA_PROM_URL="https://prometheus-prod-xxx.grafana.net/api/prom/push"
GRAFANA_PROM_USER="YOUR_PROM_USER_ID"
GRAFANA_PROM_API_KEY="YOUR_GRAFANA_CLOUD_API_KEY"
